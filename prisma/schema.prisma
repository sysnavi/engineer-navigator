generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// ユーザー・案件
// ---------------------------------------------------------------------------

enum Role {
  ENGINEER
  SALES
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  // 招待リンク認証のユーザーはメールを持たない（個人情報を保持しない方針）。
  // dev/seedユーザーとGoogle SSO移行時のみ値が入る。
  email     String?  @unique
  name      String
  role      Role     @default(ENGINEER)
  // UIカラーパレット（きせかえ）。値は src/lib/palettes.ts の PaletteId
  palette   String   @default("sky")
  // UIシェル（デスクトップOS風 or クラシック表示）。null=環境デフォルト(UI_SHELL_DEFAULT)に従う。
  // 旧UIはロールバック先ではなく「クラシックモード」として共存させる（src/lib/shell.ts）
  uiShell   String?
  // 目指す技術領域（キャリアの方向性）。値は src/lib/domains.ts の DomainDef.id。
  // メンター提案・ロールプレイ評価を本人の目標領域に寄せるために使う。
  targetDomains String[] @default([])
  // 初回オンボーディングの同意（AI解析・閲覧範囲・評価不使用）取得日時。null=未同意
  consentedAt DateTime?
  // 初回チュートリアル（アプリの歩き方）完了日時。null=未完了→初回自動表示(Issue #5)
  tutorialCompletedAt DateTime?
  // 公開共有（個人サービス）: 成長の道筋を他ユーザーが見て学べるように。デフォルト非公開。
  handle    String?  @unique // 公開URL用のハンドル（/u/<handle>）。ペンネーム可
  bio       String? // 公開プロフィールの自己紹介
  isPublic  Boolean  @default(false) // プロフィールを公開するか（本人が意識的にオン）
  // アカウント停止（スパム・過剰なAI利用対策）。null=有効。値がある間はAI機能を拒否。
  suspendedAt   DateTime?
  suspendReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments      Assignment[]
  salesProjects    Project[]         @relation("ProjectSalesRep")
  reports          WeeklyReport[]
  skills           EngineerSkill[]
  skillSuggestions SkillSuggestion[]
  conditionAlerts  ConditionAlert[]
  mentorSessions   MentorSession[]
  roleplaySessions RoleplaySession[]
  studyPlans       StudyPlan[]
  aiUsage          AiUsage[]
  invite           Invite?
  quizQuestions    QuizQuestion[]    @relation("QuizAuthor")
  quizRatings      QuizRating[]
  quizAttempts     QuizAttempt[]
  quizHidden       QuizHidden[]
  yomoyamaPosts    YomoyamaPost[]
  yomoyamaLikes    YomoyamaLike[]
  yomoyamaComments YomoyamaComment[]
  visits           UserVisit[]
  avatarGenerations AvatarGeneration[]
  dungeonRuns      DungeonRun[]
  ownedGadgets     OwnedGadget[]
}

// ローグライクダンジョン（Issue #3）: フルオート潜行の確定済みログ。
// コンテンツ（モンスター/ガジェット/罠）はDBに持たず src/lib/dungeon/content.ts の
// TSマスタをID文字列で参照する（追加=配列に足すだけ・マイグレーション不要）。
// slot が挑戦回数を構造で強制する: "d:<日付>"=1日1回 / "b:<週開始日>"=週報ボーナス週1回。
// 「◯時間で回復」等のタイマーは意図的に持たない（依存させない設計・Issue #3の議論）。
model DungeonRun {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  slot      String // "d:2026-07-19" | "b:2026-07-13"（週報ボーナス）
  createdAt DateTime @default(now())
  baseDepth Int // 出発時の基礎深度（Lv/世代/形態から導出した値のスナップショット）
  depth     Int // 最終到達階
  // 確定済みの5ステップ（出発/イベント×3/結果）。乱数はサーバーで解決済みで、
  // クライアントはこれを紙芝居再生するだけ（リプレイも同じ見た目になる）
  steps     Json

  @@unique([userId, slot])
  @@index([userId, createdAt])
}

// 戦利品ガジェットの所持（コレクション・1種1個）。gadgetId はTSマスタ参照
model OwnedGadget {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  gadgetId   String
  obtainedAt DateTime @default(now())

  @@unique([userId, gadgetId])
}

// アバター継承（転生）: 完了した世代の記録。1行 = 家系図の1段（先祖）。
// 現世代の番号は「行数 + 1」で導出。現世代EXPは exp.ts が
// 「生涯EXP（導出） − 最新行の expSnapshot + bequest」で導出する（Issue #1）。
// 遺伝子・到達形態はこの行に確定保存（EXP重みを将来変えても家系図が書き換わらないように）。
model AvatarGeneration {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  gen           Int // 第何世代として生きたか（1始まり）
  endedAt       DateTime @default(now()) // 転生（卵を産んだ）日時
  expSnapshot   Int // 転生時点の生涯EXP。現世代EXP導出の基準点
  expInGen      Int // この世代で稼いだEXP（家系図表示用に確定保存）
  levelAtEnd    Int
  stageAtEnd    String // 到達形態の名前（"マイスター" 等）
  spriteAtEnd   String // 到達形態のスプライトID（家系図でのアバター表示用）
  dominantGene  String // 優性遺伝子（src/lib/genes.ts の GeneId）
  recessiveGene String? // 劣性遺伝子（活動が1カテゴリに偏っていた世代は null）
  bequest       Int // 次世代に引き継ぐ初期EXP（遺産）。転生時に確定
  // 活動集計。cumulative=転生時点の生涯集計（次世代の遺伝子判定の基準点）、
  // inGen=この世代分の差分（家系図の実績ハイライト表示用）
  summary       Json

  @@unique([userId, gen])
}

// サイト訪問の記録（1日1行）。訪問EXPと連続ログインストリークの算出に使う。
// 記録はレイアウトで（ログイン済みのページ表示時に skipDuplicates で1回だけ）。
model UserVisit {
  id     String   @id @default(cuid())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  date   DateTime @db.Date

  @@unique([userId, date])
}

// よもやま掲示板（Phase 6）: 現場の悲喜こもごもをハンドル名で共有。
// 投稿はAI門番(src/lib/ai/moderation.ts)を通過したものだけ保存される。
model YomoyamaPost {
  id            String   @id @default(cuid())
  author        User     @relation(fields: [authorId], references: [id])
  authorId      String
  body          String
  // 投稿者が他者コメントの受付をON/OFFできる（OFF時は新規コメント不可・既存は残る）
  allowComments Boolean  @default(true)
  createdAt     DateTime @default(now())

  likes    YomoyamaLike[]
  comments YomoyamaComment[]

  @@index([createdAt])
}

// いいね（postId+userId ユニークで二重いいね防止）
model YomoyamaLike {
  id        String       @id @default(cuid())
  post      YomoyamaPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

// コメント。投稿と同じAI門番を通過したものだけ保存。管理者はソフト削除（監査可能）。
model YomoyamaComment {
  id          String       @id @default(cuid())
  post        YomoyamaPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    String
  body        String
  createdAt   DateTime     @default(now())
  deletedAt   DateTime? // 管理者削除の記録。表示は「削除されました」
  deletedById String? // 削除した管理者のUserId（監査用・関係は張らない）

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
}

// 良問バンク（Phase 5）: ユーザーが四択問題を作り、みんなで解いて育てる。
// 採点はローカル完結（AIトークン消費ゼロ）。良問スコアは全員の評価の集計で決まる。
model QuizQuestion {
  id          String   @id @default(cuid())
  author      User     @relation("QuizAuthor", fields: [authorId], references: [id])
  authorId    String
  topic       String // お題（例: "AWS IAM" "TCP/IP"）。出題の絞り込みに使う
  domains     String[] @default([]) // 関連技術領域（src/lib/domains.ts のID・任意）
  prompt      String
  choices     String[] // 選択肢（4つ想定）
  answerIndex Int // 正解の選択肢index（クライアントには渡さず採点はサーバー）
  explanation String?
  // 良問スコアの集計（全員分の評価を集約。若手の誤評価対策で個人でなく総意を採用）
  ratingSum   Int      @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())

  ratings  QuizRating[]
  attempts QuizAttempt[]
  hiddenBy QuizHidden[]

  @@index([topic])
}

// ユーザーが「もう表示しなくていい」と指定した問題（本人にだけ出題されなくなる）
model QuizHidden {
  id         String       @id @default(cuid())
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
  user       User         @relation(fields: [userId], references: [id])
  userId     String
  createdAt  DateTime     @default(now())

  @@unique([questionId, userId])
  @@index([userId])
}

// 1問への評価（0-10）。1人1票・上書き可。集計は QuizQuestion 側に反映。
model QuizRating {
  id         String       @id @default(cuid())
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
  user       User         @relation(fields: [userId], references: [id])
  userId     String
  score      Int
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([questionId, userId])
}

// 解答履歴（正誤の記録・統計と「解いた問題」の把握に使う）
model QuizAttempt {
  id          String       @id @default(cuid())
  question    QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId  String
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  chosenIndex Int
  correct     Boolean
  createdAt   DateTime     @default(now())

  @@index([userId, questionId])
}

// 招待リンク認証（個人情報を持たない方針）。メール/パスワードの代わりに
// 不透明トークンを1人1本発行し、それ自体がログイン資格になる。漏れても1人分・失効可能。
model Invite {
  id        String    @id @default(cuid())
  token     String    @unique // URLに載る不透明トークン（推測不可）
  note      String? // 管理用の目印（例:「Aさん用」）。PIIは入れない運用
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?   @unique // 引き換え時に作られる/紐づくユーザー
  createdAt DateTime  @default(now())
  revokedAt DateTime? // 失効（このトークンでのログインを無効化）
}

// AI呼び出しの利用ログ。直近の件数からレート制限・自動停止を判定する（スパム対策）。
model AiUsage {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  kind      String // 用途タグ（mentor-chat / roleplay-chat / interview / report-analysis 等）
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Project {
  id          String  @id @default(cuid())
  name        String
  // 顧客名は機密のため表示用の別名のみ保持する
  clientAlias String?
  salesRep    User?   @relation("ProjectSalesRep", fields: [salesRepId], references: [id])
  salesRepId  String?

  assignments Assignment[]
  createdAt   DateTime     @default(now())
}

model Assignment {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  project   Project   @relation(fields: [projectId], references: [id])
  projectId String
  roleNote  String? // 現場での役割（例: バックエンド実装、テストリーダー）
  startedAt DateTime
  endedAt   DateTime?
}

// ---------------------------------------------------------------------------
// 週報（すべてのデータの源泉）— 設計は docs/weekly-report.md
// ---------------------------------------------------------------------------

enum ReportStatus {
  DRAFT
  SUBMITTED
}

model WeeklyReport {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  weekStart DateTime @db.Date // その週の月曜日

  // 選択式（1=悪い/低い 〜 4=良い/余裕）
  conditionSelf Int? // ☀️4 🌤3 ☁️2 🌧1
  workloadSelf  Int? // 余裕あり4 〜 限界が近い1

  // 自由記述
  didText      String? // 今週やったこと
  newText      String? // 新しく触れた技術・初めてやったこと
  struggleText String? // 詰まったこと・モヤモヤ
  nextText     String? // 来週やること
  shareText    String? // 会社への共有・相談

  wantsConsultation Boolean      @default(false) // 営業に直接相談したい
  // 公開共有: この週報を公開プロフィールに載せるか。デフォルト非公開。
  // 公開時もコンディション（設問1・2・5・7とスコア）は表示しない — 成長の記録のみ。
  isPublic          Boolean      @default(false)
  status            ReportStatus @default(DRAFT)
  submittedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  analysis         ReportAnalysis?
  skillSuggestions SkillSuggestion[]

  @@unique([userId, weekStart])
}

enum AnalysisStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model ReportAnalysis {
  id       String         @id @default(cuid())
  report   WeeklyReport   @relation(fields: [reportId], references: [id])
  reportId String         @unique
  status   AnalysisStatus @default(PENDING)

  extractedSkills Json? // 抽出した技術・工程・役割の構造化データ
  conditionAi     Float? // AIトーン解析スコア（0-100）
  divergence      Float? // 自己申告とAI解析の乖離（「弱音を書けない」シグナル）
  signals         Json? // 要対応シグナル（相談検知など）
  feedbackText    String? // 本人向け「今週の成長ポイント」

  model        String?
  inputTokens  Int?
  outputTokens Int?
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// スキルマップ
// ---------------------------------------------------------------------------

enum SkillCategory {
  LANGUAGE
  FRAMEWORK
  CLOUD
  DATABASE
  AI
  TOOL
  PROCESS // 工程（要件定義・設計・テスト等）
  SOFT // リーダーシップ・顧客調整等
  OTHER
}

model Skill {
  id       String        @id @default(cuid())
  name     String        @unique
  category SkillCategory
  aliases  String[] // 表記ゆれ（例: "Go" / "Golang"）

  engineerSkills   EngineerSkill[]
  skillSuggestions SkillSuggestion[]
}

model EngineerSkill {
  id               String    @id @default(cuid())
  user             User      @relation(fields: [userId], references: [id])
  userId           String
  skill            Skill     @relation(fields: [skillId], references: [id])
  skillId          String
  level            Int // 1-5
  monthsExperience Int?
  lastUsedAt       DateTime?
  updatedAt        DateTime  @updatedAt

  histories SkillHistory[]

  @@unique([userId, skillId])
}

// 成長グラフ用の履歴（レベルが変わるたびに1行）
model SkillHistory {
  id              String        @id @default(cuid())
  engineerSkill   EngineerSkill @relation(fields: [engineerSkillId], references: [id])
  engineerSkillId String
  level           Int
  changedAt       DateTime      @default(now())
  sourceNote      String? // 例: "2026-W28 週報のAI提案を承認"
}

enum SuggestionKind {
  NEW_SKILL // 未登録スキルの新規追加
  LEVEL_UP // 既存スキルのレベルアップ
  EXPERIENCE // 経歴書に載せる実績（本番リリース等）
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model SkillSuggestion {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  kind           SuggestionKind
  skill          Skill?         @relation(fields: [skillId], references: [id])
  skillId        String?
  skillName      String // AIが抽出した生の名称
  suggestedLevel Int?
  reason         String // 提案理由
  evidenceQuote  String? // 週報からの引用（エビデンス）

  sourceReport   WeeklyReport @relation(fields: [sourceReportId], references: [id])
  sourceReportId String

  status    SuggestionStatus @default(PENDING)
  decidedAt DateTime?
  createdAt DateTime         @default(now())
}

// ---------------------------------------------------------------------------
// コンディション検知（Phase 2）
// ---------------------------------------------------------------------------

enum AlertLevel {
  INFO
  WARN
  CRITICAL
}

enum AlertStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model ConditionAlert {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  level   AlertLevel
  trigger String // 発火ルール名（例: "3週連続下降トレンド" "相談フラグ"）
  reason  String

  status    AlertStatus @default(OPEN)
  note      String? // 対応記録（面談メモ）
  closedAt  DateTime?
  createdAt DateTime    @default(now())
}

// ---------------------------------------------------------------------------
// AIメンター（Phase 3）
// ---------------------------------------------------------------------------

enum ChatRole {
  USER
  ASSISTANT
}

model MentorSession {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  topic         String? // 例: "AWS SAA" "JSTQB FL"
  certification String?
  createdAt     DateTime @default(now())

  messages MentorMessage[]
}

model MentorMessage {
  id        String        @id @default(cuid())
  session   MentorSession @relation(fields: [sessionId], references: [id])
  sessionId String
  role      ChatRole
  content   String
  createdAt DateTime      @default(now())
}

// ---------------------------------------------------------------------------
// 「一歩先の役割」シミュレーター（Phase 4）
// ---------------------------------------------------------------------------

model RoleplayScenario {
  id          String   @id @default(cuid())
  title       String // 例: "顧客からの無理な仕様変更"
  description String
  persona     String // AIが演じる役（顧客・メンバー等）の設定
  objectives  Json // 評価観点（リーダー職務定義書ベース）
  // 8bitカードの識別用アイコン
  emoji       String   @default("🎯")
  // 関連する技術領域（src/lib/domains.ts のID）。シャッフルで本人の目標領域を優先するのに使う
  domains     String[] @default([])
  createdAt   DateTime @default(now())

  sessions RoleplaySession[]
}

enum RoleplaySessionStatus {
  IN_PROGRESS
  COMPLETED
}

model RoleplaySession {
  id         String                @id @default(cuid())
  user       User                  @relation(fields: [userId], references: [id])
  userId     String
  scenario   RoleplayScenario      @relation(fields: [scenarioId], references: [id])
  scenarioId String
  status     RoleplaySessionStatus @default(IN_PROGRESS)
  feedback   String? // 終了後の自動フィードバック
  createdAt  DateTime              @default(now())

  messages RoleplayMessage[]
}

model RoleplayMessage {
  id        String          @id @default(cuid())
  session   RoleplaySession @relation(fields: [sessionId], references: [id])
  sessionId String
  role      ChatRole
  content   String
  createdAt DateTime        @default(now())
}

// ---------------------------------------------------------------------------
// 資格別学習プラン（Phase 3）— 試験日からの逆算カリキュラム + 進捗トラッキング
// ---------------------------------------------------------------------------

enum StudyPlanStatus {
  ACTIVE
  DONE
  ARCHIVED
}

model StudyPlan {
  id            String          @id @default(cuid())
  user          User            @relation(fields: [userId], references: [id])
  userId        String
  certification String // 例: "AWS SAA" "JSTQB FL"
  examDate      DateTime        @db.Date // 試験日
  status        StudyPlanStatus @default(ACTIVE)
  createdAt     DateTime        @default(now())

  items StudyPlanItem[]
}

model StudyPlanItem {
  id         String    @id @default(cuid())
  plan       StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId     String
  order      Int // 表示順（0始まり）
  weekLabel  String? // 例: "1週目" "直前1週間"
  title      String // 学習マイルストーン
  detail     String? // 具体的な学習内容
  targetDate DateTime? @db.Date // この項目の目安完了日
  done       Boolean   @default(false)
  doneAt     DateTime?

  @@index([planId])
}

// ---------------------------------------------------------------------------
// 会社独自ノウハウのRAG — 埋め込みは Voyage AI（voyage-3.5, 1024次元）
// embedding列と類似検索は raw SQL で扱う（Prismaのvector未対応のため）。
// 投入は scripts/ingest-knowledge.ts、検索は src/lib/ai/retrieval.ts。
//
// AIの提案・評価を「Claudeの一般知識」ではなく「会社のノウハウ」で裏付けるための器。
// kind で用途を分け、機能ごとに検索対象を絞る（例: 週報のスキル判定に職務定義書が
// 混ざらないようにする）。
// ---------------------------------------------------------------------------

enum KnowledgeKind {
  LEARNING // 学習コンテンツ（AWS/JSTQBシラバス・社内研修資料）→ メンター・学習プラン
  SKILL_CRITERIA // 社内のスキル判定基準・レベル定義・単価の分水嶺 → 週報のスキル抽出
  CONDITION_PLAYBOOK // コンディション対応の事例・1on1のノウハウ → コンディション助言
  ROLE_DEFINITION // リーダー職務定義書・評価基準 → 役割シミュレーターの評価
  RATE_EVIDENCE // 単価交渉で実際に効いた実績パターン → 経歴書のハイライト
}

model KnowledgeChunk {
  id         String                       @id @default(cuid())
  kind       KnowledgeKind // この知識の用途
  source     String // 資料名（例: "AWS IAM 入門" "シスナビ スキル判定基準"）
  sourceUrl  String? // 任意の出典URL
  topic      String? // 補助タグ（例: "AWS SAA" "リーダー"）
  content    String // チャンク本文
  chunkIndex Int
  embedding  Unsupported("vector(1024)")?
  createdAt  DateTime                     @default(now())

  @@index([kind])
  @@index([source])
}
