# PostgreSQL（docker compose up -d で起動するローカルDB）
DATABASE_URL="postgresql://navi:navi@localhost:5433/engineer_navigator"

# Claude API（AI解析・メンター・ロールプレイで使用）
ANTHROPIC_API_KEY=""

# 開発用ログイン（ユーザー切替UIが有効・ゲート無効）。本番では設定しない（招待リンク認証のみ）
DEV_LOGIN_ENABLED="true"

# UIシェルの全体デフォルト（"desktop"=レトロOSデスクトップ / "classic"=従来ナビ。未設定=classic）。
# ユーザーはマイページのUIモードで個別に上書きできる。ロールバックはgitでなくこの設定で行う
# UI_SHELL_DEFAULT="desktop"

# 管理者ブートストラップ用の招待トークン。本番ではランダムな長い文字列を設定し、
# seed 後に /join/<この値> を一度開くと管理者としてログインできる。以後はADMIN画面で発行。
ADMIN_INVITE_TOKEN=""

# AIレート制限のしきい値（未設定なら既定 15/分・300/日・600/日で自動停止）
# AI_RATE_PER_MINUTE="15"
# AI_RATE_PER_DAY="300"
# AI_AUTO_SUSPEND_PER_DAY="600"

# Slack Incoming Webhook（コンディションアラートの外部通知。未設定ならconsoleログのみ）
# 注意: 投稿先は営業・管理者のみの限定チャンネルにすること（通知に氏名が含まれる）
SLACK_WEBHOOK_URL=""

# 週次ジョブ (POST /api/jobs/weekly) の認証シークレット。未設定ならジョブは503
JOB_SECRET=""

# 通知内のリンク生成に使うベースURL
APP_URL="http://localhost:3000"

# Voyage AI 埋め込みAPI（AIメンターのRAG検索。未設定ならRAGはスキップされClaude知識ベースのみ）
# https://www.voyageai.com/ で取得。設定後 `npm run ingest:learning` で学習コンテンツを投入
VOYAGE_API_KEY=""
