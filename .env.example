# PostgreSQL（docker compose up -d で起動するローカルDB）
DATABASE_URL="postgresql://navi:navi@localhost:5433/engineer_navigator"

# Claude API（AI解析・メンター・ロールプレイで使用）
ANTHROPIC_API_KEY=""

# 開発用ログインで使うデモユーザーのメール（本番はGoogle SSOに置き換え）
DEV_LOGIN_ENABLED="true"

# Slack Incoming Webhook（コンディションアラートの外部通知。未設定ならconsoleログのみ）
# 注意: 投稿先は営業・管理者のみの限定チャンネルにすること（通知に氏名が含まれる）
SLACK_WEBHOOK_URL=""

# 週次ジョブ (POST /api/jobs/weekly) の認証シークレット。未設定ならジョブは503
JOB_SECRET=""

# 通知内のリンク生成に使うベースURL
APP_URL="http://localhost:3000"
